# Command: resume
# Normal: restarts current phase from scratch (new conversation)
# --graceful: restores exact conversation using saved session ID
cmd_resume() {
    local project_path=""
    local graceful_mode=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --graceful|-g)
                graceful_mode="true"
                shift
                ;;
            -*)
                die "Unknown option: $1. Usage: ./pipeline resume <project> [--graceful]"
                ;;
            *)
                project_path="$1"
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline resume <project> [--graceful]"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    local project_name=$(basename "$project_path")
    local pipeline_dir="$project_path/.pipeline"
    local graceful_state="$pipeline_dir/graceful-state.json"
    local session_file="$pipeline_dir/session-id"
    local manifest="$pipeline_dir/manifest.json"

    # GRACEFUL RESUME: Restore exact conversation
    if [[ "$graceful_mode" == "true" ]]; then
        print_header "GRACEFUL RESUME"
        echo ""
        echo "Project: $project_path"
        echo ""

        # Check for saved session state
        local session_id=""
        if [[ -f "$graceful_state" ]]; then
            local can_resume=$(jq -r '.canGracefulResume // false' "$graceful_state")
            session_id=$(jq -r '.sessionId // ""' "$graceful_state")
            local saved_phase=$(jq -r '.currentPhase // "unknown"' "$graceful_state")
            local saved_at=$(jq -r '.savedAt // "unknown"' "$graceful_state")

            echo "Saved state found:"
            echo "  Session: $session_id"
            echo "  Phase: $saved_phase"
            echo "  Saved at: $saved_at"
            echo ""

            if [[ "$can_resume" != "true" ]] || [[ -z "$session_id" ]]; then
                warn "Graceful resume not available (no session ID saved)"
                echo "Falling back to normal resume (restart phase)..."
                echo ""
                graceful_mode=""
            fi
        elif [[ -f "$session_file" ]]; then
            # Try legacy session-id file
            session_id=$(cat "$session_file")
            echo "Using legacy session file: $session_id"
        else
            warn "No saved session state found"
            echo "Use --graceful with stop first:"
            echo "  ./pipeline stop --graceful $project_path"
            echo ""
            echo "Falling back to normal resume..."
            graceful_mode=""
        fi

        if [[ "$graceful_mode" == "true" ]] && [[ -n "$session_id" ]]; then
            echo "Restoring exact conversation..."
            echo "Claude will continue from where you left off."
            echo "All previous context (todos, messages) preserved."
            print_header ""

            cd "$project_path"

            # Auto-detect foreground vs tmux mode
            local use_foreground=""
            if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "${WINDIR:-}" ]] || ! command -v tmux &>/dev/null; then
                use_foreground="true"
            fi

            if [[ "$use_foreground" == "true" ]]; then
                # Foreground mode - run Claude directly with --resume
                echo "Running in foreground mode (Ctrl+C to stop)"
                echo "────────────────────────────────────────────────────────────────"
                claude --resume "$session_id" --dangerously-skip-permissions
            else
                # tmux mode
                local session_name="worker-${project_name}"
                tmux kill-session -t "$session_name" 2>/dev/null || true
                sleep 0.5

                tmux new-session -d -s "$session_name" -c "$project_path"
                sleep 0.5

                tmux send-keys -t "$session_name" "claude --resume $session_id --dangerously-skip-permissions" Enter

                echo "Session restored in tmux: $session_name"
                echo ""
                echo "Commands:"
                echo "  tmux attach -t $session_name  # View session"
                echo "  ./pipeline send $project_path \"message\"  # Send message"
                echo "  ./pipeline stop $project_path  # Stop"

                # Auto-attach if interactive
                if [[ -t 0 ]]; then
                    echo ""
                    echo "Attaching to session (Ctrl+B D to detach)..."
                    sleep 1
                    tmux attach-session -t "$session_name"
                fi
            fi

            return 0
        fi
    fi

    # NORMAL RESUME: Restart current phase (new conversation)
    print_header "RESUME PIPELINE"
    echo ""
    echo "Project: $project_path"

    # Read current phase from manifest
    local current_phase="1"
    if [[ -f "$manifest" ]]; then
        current_phase=$(jq -r '.currentPhase // "1"' "$manifest")
    fi

    echo "Current phase: $current_phase"
    echo ""
    echo "This will start a NEW conversation at phase $current_phase."
    echo "Previous work (files, tests) is preserved."
    echo "Previous conversation context is NOT preserved."
    print_header ""

    # Use the run-pipeline.sh with --from to resume at current phase
    exec "$SCRIPT_DIR/run-pipeline.sh" "$project_path" --from "$current_phase"
}

