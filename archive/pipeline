# Command: signal - Signal phase completion (DEPRECATED in v6.0)
# In v6.0, supervisor reads worker output to determine completion.
# This command is kept for backward compatibility but is no longer used.
cmd_signal() {
    echo "⚠️  DEPRECATED: Signal command is deprecated in v6.0"
    echo "   Supervisor now reads worker output to determine phase completion."
    echo "   This command still works but is no longer recommended."
    echo ""

    local phase=""
    local tests_passing=""
    local tests_failing=""
    local project_path=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --tests-passing)
                tests_passing="$2"
                shift 2
                ;;
            --tests-failing)
                tests_failing="$2"
                shift 2
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                if [ -z "$phase" ]; then
                    phase="$1"
                elif [ -z "$project_path" ]; then
                    project_path="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [ -z "$phase" ] && die "Phase required. Usage: ./pipeline signal <phase> [project] [--tests-passing N] [--tests-failing N]"

    # Default to current directory
    if [ -z "$project_path" ]; then
        project_path="$(pwd)"
    fi

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    # Validate phase
    case "$phase" in
        0a|0b|1|2|3|0a-feature|0b-feature|1-feature|2-feature|3-feature)
            ;;
        *)
            die "Invalid phase: $phase. Valid phases: 0a, 0b, 1, 2, 3 (and -feature variants)"
            ;;
    esac

    # Create signal file
    local signal_dir="$project_path/.pipeline"
    local signal_file="$signal_dir/.signal-${phase}-complete"
    local timestamp=$(date -Iseconds)

    mkdir -p "$signal_dir"

    # Build JSON signal
    local json="{\"phase\":\"$phase\",\"timestamp\":\"$timestamp\""

    if [ -n "$tests_passing" ]; then
        json="$json,\"tests_passing\":$tests_passing"
    fi
    if [ -n "$tests_failing" ]; then
        json="$json,\"tests_failing\":$tests_failing"
    fi

    json="$json}"

    echo "$json" > "$signal_file"

    echo "✓ Phase $phase signaled complete"
    echo "  Signal file: $signal_file"

    # Also update checkpoint for compatibility
    local checkpoint="$signal_dir/checkpoint.json"
    local checkpoint_json="{\"lastAction\":\"phase-${phase}-complete\",\"timestamp\":\"$timestamp\",\"phase\":\"$phase\""

    if [ -n "$tests_passing" ] || [ -n "$tests_failing" ]; then
        checkpoint_json="$checkpoint_json,\"tests\":{\"passing\":${tests_passing:-0},\"failing\":${tests_failing:-0}}"
    fi

    checkpoint_json="$checkpoint_json}"
    echo "$checkpoint_json" > "$checkpoint"

    # Update manifest to mark phase complete (critical for resume)
    local manifest="$signal_dir/manifest.json"
    local phase_key="${phase%-feature}"  # Remove -feature suffix for manifest lookup
    if [[ -f "$manifest" ]]; then
        local next_phase=""
        case "$phase_key" in
            0a) next_phase="0b" ;;
            0b) next_phase="1" ;;
            1)  next_phase="2" ;;
            2)  next_phase="3" ;;
            3)  next_phase="" ;;
        esac

        # Update phase status and currentPhase
        if [[ -n "$next_phase" ]]; then
            jq ".phases[\"$phase_key\"].status = \"complete\" | .phases[\"$phase_key\"].completedAt = \"$timestamp\" | .currentPhase = \"$next_phase\"" \
                "$manifest" > "${manifest}.tmp" && mv "${manifest}.tmp" "$manifest"
        else
            jq ".phases[\"$phase_key\"].status = \"complete\" | .phases[\"$phase_key\"].completedAt = \"$timestamp\" | .status = \"complete\" | .completedAt = \"$timestamp\"" \
                "$manifest" > "${manifest}.tmp" && mv "${manifest}.tmp" "$manifest"
        fi
        echo "  Manifest updated: phase $phase_key → complete, currentPhase → ${next_phase:-done}"
    fi
}

