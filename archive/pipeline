# Command: monitor - Persistent monitoring with interval checks (for AI use)
cmd_monitor() {
    local project_path=""
    local interval=300  # Default 5 minutes
    local max_checks=72   # Default ~6 hours max (72 * 5min = 360min)

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --interval|-i)
                interval="$2"
                shift 2
                ;;
            --max-checks|-m)
                max_checks="$2"
                shift 2
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                project_path="$1"
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline monitor <project> [--interval N] [--max-checks N]"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"
    require_jq

    local project_name=$(basename "$project_path")
    local manifest="$project_path/.pipeline/manifest.json"
    local check_count=0
    local start_time=$(date +%s)

    echo "════════════════════════════════════════════════════════════════"
    echo "PERSISTENT PIPELINE MONITOR"
    echo "════════════════════════════════════════════════════════════════"
    echo "Project: $project_name"
    echo "Interval: ${interval}s"
    echo "Max checks: $max_checks"
    echo "Started: $(date)"
    echo "════════════════════════════════════════════════════════════════"
    echo ""

    while [ $check_count -lt $max_checks ]; do
        check_count=$((check_count + 1))
        local elapsed=$(($(date +%s) - start_time))
        local elapsed_min=$((elapsed / 60))

        echo "────────────────────────────────────────────────────────────────"
        echo "[Check #$check_count] $(date '+%H:%M:%S') (${elapsed_min}m elapsed)"
        echo "────────────────────────────────────────────────────────────────"

        # Check if tmux session exists
        local session_name="pipeline-${project_name}"
        local session_exists="no"
        if tmux has-session -t "$session_name" 2>/dev/null; then
            session_exists="yes"
        fi
        echo "Session active: $session_exists"

        # Check manifest status
        if [ -f "$manifest" ]; then
            local current_phase=$(jq -r '.currentPhase // "unknown"' "$manifest")
            local project_status=$(jq -r '.status // "unknown"' "$manifest")
            local current_epic=$(jq -r '.currentEpic // 0' "$manifest")
            local total_epics=$(jq '.epics | length // 0' "$manifest")
            local completed_epics=$(jq '[.epics[] | select(.status == "complete")] | length' "$manifest")
            local tests_passing=$(jq -r '.tests.passing // 0' "$manifest")
            local tests_total=$(jq -r '.tests.total // 0' "$manifest")

            echo "Phase: $current_phase"
            echo "Status: $project_status"
            echo "Epic: $current_epic / $total_epics ($completed_epics complete)"
            echo "Tests: $tests_passing / $tests_total passing"

            # Check for completion
            if [ "$project_status" = "complete" ]; then
                echo ""
                echo "════════════════════════════════════════════════════════════════"
                echo "✅ PIPELINE COMPLETE!"
                echo "════════════════════════════════════════════════════════════════"
                echo "Total time: ${elapsed_min} minutes"
                echo "Final phase: $current_phase"
                echo "Tests passing: $tests_passing / $tests_total"
                return 0
            fi

            # Check for failure indicators
            if [ "$project_status" = "failed" ]; then
                echo ""
                echo "════════════════════════════════════════════════════════════════"
                echo "❌ PIPELINE FAILED!"
                echo "════════════════════════════════════════════════════════════════"
                echo "Failed at phase: $current_phase"
                echo "Check logs for details"
                return 1
            fi

            # Check if session died but status not complete
            if [ "$session_exists" = "no" ] && [ "$project_status" = "in-progress" ]; then
                echo ""
                echo "⚠️  WARNING: Session not running but status is in-progress"
                echo "   Pipeline may have crashed. Check: ./pipeline status $project_path"
            fi
        else
            echo "No manifest found"
        fi

        # Check for signal files
        local signals
        signals=$(ls "$project_path/.pipeline/.signal-"*"-complete" 2>/dev/null | wc -l) || signals=0
        if [ "$signals" -gt 0 ]; then
            echo "Signal files: $signals"
        fi

        echo ""

        # Wait for next check (unless last iteration)
        if [ $check_count -lt $max_checks ]; then
            echo "Next check in ${interval}s..."
            sleep $interval
        fi
    done

    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "⏰ MAX CHECKS REACHED ($max_checks)"
    echo "════════════════════════════════════════════════════════════════"
    echo "Pipeline did not complete within monitoring window"
    echo "Last status: $(jq -r '.status // "unknown"' "$manifest" 2>/dev/null)"
    return 2
}

# Command: auto-monitor - Monitor pipeline and send updates to another tmux session
cmd_auto_monitor() {
    local project_path=""
    local target_session=""
    local interval=300  # Default 5 minutes
    local max_checks=72   # Default ~6 hours (72 * 5min = 360min)

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --target|-t)
                target_session="$2"
                shift 2
                ;;
            --interval|-i)
                interval="$2"
                shift 2
                ;;
            --max-checks|-m)
                max_checks="$2"
                shift 2
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                project_path="$1"
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Usage: ./pipeline auto-monitor <project> --target <tmux-session> [--interval N]"
    [ -z "$target_session" ] && die "Target session required. Usage: ./pipeline auto-monitor <project> --target <tmux-session>"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"
    require_jq

    # Verify target session exists
    if ! tmux has-session -t "$target_session" 2>/dev/null; then
        die "Target tmux session '$target_session' not found. List sessions with: tmux ls"
    fi

    local project_name=$(basename "$project_path")
    local manifest="$project_path/.pipeline/manifest.json"
    local check_count=0
    local start_time=$(date +%s)
    local last_phase=""
    local last_tests=""

    echo "Auto-monitor started for $project_name"
    echo "Target session: $target_session"
    echo "Interval: ${interval}s"

    # Send initial message (use -- to prevent message being parsed as options)
    tmux send-keys -t "$target_session" -- ""  # Clear any pending input
    sleep 0.1
    tmux send-keys -t "$target_session" -- "[Heartbeat] Started. Check worker progress."
    tmux send-keys -t "$target_session" Enter

    while [ $check_count -lt $max_checks ]; do
        check_count=$((check_count + 1))
        sleep $interval

        local elapsed=$(($(date +%s) - start_time))
        local elapsed_min=$((elapsed / 60))

        # Check session still exists
        if ! tmux has-session -t "$target_session" 2>/dev/null; then
            echo "Target session closed. Stopping monitor."
            return 0
        fi

        # Check worker session (try both new and legacy naming)
        local worker_session="worker-${project_name}"
        local legacy_session="pipeline-${project_name}"
        local session_active="no"
        if tmux has-session -t "$worker_session" 2>/dev/null; then
            session_active="yes"
        elif tmux has-session -t "$legacy_session" 2>/dev/null; then
            session_active="yes"
        fi

        # Get status from manifest
        local current_phase="?"
        local project_status="?"
        local tests_passing="0"
        local tests_total="0"
        local current_epic="0"
        local total_epics="0"

        if [ -f "$manifest" ]; then
            current_phase=$(jq -r '.currentPhase // "?"' "$manifest")
            project_status=$(jq -r '.status // "?"' "$manifest")
            tests_passing=$(jq -r '.tests.passing // 0' "$manifest")
            tests_total=$(jq -r '.tests.total // 0' "$manifest")
            current_epic=$(jq -r '.currentEpic // 0' "$manifest")
            total_epics=$(jq '.epics | length // 0' "$manifest")
        fi

        # Build status line (for local logging only)
        local status_line="[${elapsed_min}m] Phase:$current_phase Epic:$current_epic/$total_epics Tests:$tests_passing/$tests_total Session:$session_active"

        # Heartbeat message - supervisor reads worker output to judge progress
        local heartbeat_msg="[Heartbeat] Check worker progress."

        # Send heartbeat every interval
        tmux send-keys -t "$target_session" -- "$heartbeat_msg"
        tmux send-keys -t "$target_session" Enter

        # Exit conditions (heartbeat stops when pipeline ends)
        if [ "$project_status" = "complete" ]; then
            echo "Pipeline complete!"
            return 0
        fi
        if [ "$project_status" = "failed" ] || { [ "$session_active" = "no" ] && [ "$project_status" = "in-progress" ]; }; then
            echo "Pipeline needs attention!"
            return 1
        fi

        echo "[Check $check_count] $status_line"
    done

    tmux send-keys -t "$target_session" -- "Monitor timeout after ${elapsed_min}m"
    tmux send-keys -t "$target_session" Enter
    return 2
}

# Command: supervise - Start Supervisor Claude that orchestrates workers
cmd_supervise() {
    local project_path=""
    local interval=120
    local feature_mode=""
    local from_phase=""
    local offload_target=""
    local foreground_mode=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --interval|-i)
                interval="$2"
                shift 2
                ;;
            --feature|-f)
                feature_mode="--feature"
                shift
                ;;
            --from)
                from_phase="$2"
                shift 2
                ;;
            --offload|-o)
                offload_target="$2"
                shift 2
                ;;
            --foreground|--fg)
                foreground_mode="true"
                shift
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                project_path="$1"
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Usage: ./pipeline supervise <project> [--interval N] [--feature] [--from <phase>] [--foreground]"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path" true

    local project_name=$(basename "$project_path")
    local supervisor_session="supervisor-${project_name}"

    # Auto-detect Windows/no-tmux
    if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "${WINDIR:-}" ]] || ! command -v tmux &>/dev/null; then
        if [[ -z "$foreground_mode" ]]; then
            echo "⚠️  tmux not available. Running in foreground mode."
            foreground_mode="true"
        fi
    fi

    # Determine mode for supervisor
    local mode="new-project"
    if [ -n "$feature_mode" ]; then
        mode="feature"
    elif [ -n "$from_phase" ]; then
        mode="resume --from $from_phase"
    fi

    print_header "SUPERVISED PIPELINE"
    echo ""
    echo "Project: $project_name"
    echo "Mode: $mode"
    if [ "$foreground_mode" = "true" ]; then
        echo "Run Mode: Foreground (Windows)"
    else
        echo "Supervisor: $supervisor_session"
    fi
    if [ -n "$offload_target" ]; then
        echo "Offload to: $offload_target (workers run remotely)"
    fi
    echo "Heartbeat interval: ${interval}s"
    echo ""

    # ═══════════════════════════════════════════════════════════════
    # FOREGROUND MODE (Windows / no-tmux)
    # ═══════════════════════════════════════════════════════════════
    if [ "$foreground_mode" = "true" ]; then
        local log_file="$project_path/.pipeline/supervisor.log"
        local msg_file="$project_path/.pipeline/user-message.txt"
        mkdir -p "$project_path/.pipeline"

        echo "Log file: $log_file"
        echo ""
        echo "Commands (run in another terminal):"
        echo "  ./pipeline watch $project_path     # View output"
        echo "  ./pipeline send $project_path \"msg\" # Send message"
        echo "  Ctrl+C                              # Stop"
        echo ""
        print_header "Starting Supervisor..."

        # Initialize manifest if needed
        local manifest="$project_path/.pipeline/manifest.json"
        if [ ! -f "$manifest" ]; then
            local run_id=$(date +%Y%m%d-%H%M%S)
            "$SCRIPT_DIR/init-manifest.sh" "$project_path" "$run_id" "new-project" 2>/dev/null || true
        fi

        # Build supervisor command
        local supervisor_cmd="/supervisor $project_path --mode $mode"

        # Clear message file
        rm -f "$msg_file"

        # Run Claude directly in foreground
        cd "$project_path"
        echo "════════════════════════════════════════════════════════════════" | tee -a "$log_file"
        echo "Supervisor started at $(date)" | tee -a "$log_file"
        echo "Command: $supervisor_cmd" | tee -a "$log_file"
        echo "════════════════════════════════════════════════════════════════" | tee -a "$log_file"

        # Start Claude with input from message file polling
        (
            echo "$supervisor_cmd"
            while true; do
                if [[ -f "$msg_file" ]]; then
                    cat "$msg_file"
                    rm -f "$msg_file"
                fi
                sleep 2
            done
        ) | claude --dangerously-skip-permissions 2>&1 | tee -a "$log_file"

        echo ""
        print_header "Supervisor Ended"
        return 0
    fi

    # ═══════════════════════════════════════════════════════════════
    # TMUX MODE (Linux/VPS)
    # ═══════════════════════════════════════════════════════════════

    # Kill existing sessions if any
    tmux kill-session -t "$supervisor_session" 2>/dev/null || true
    tmux kill-session -t "worker-${project_name}" 2>/dev/null || true
    sleep 1

    # Initialize manifest if needed
    local manifest="$project_path/.pipeline/manifest.json"
    if [ ! -f "$manifest" ]; then
        local run_id=$(date +%Y%m%d-%H%M%S)
        "$SCRIPT_DIR/init-manifest.sh" "$project_path" "$run_id" "new-project" 2>/dev/null || true
    fi

    # Reset manifest status so supervisor can work
    if [ -f "$manifest" ]; then
        local tmp_manifest=$(mktemp)
        jq '.status = "in-progress"' "$manifest" > "$tmp_manifest" && mv "$tmp_manifest" "$manifest"
    fi

    # 1. Create Supervisor session
    echo "Starting Supervisor Claude..."
    tmux new-session -d -s "$supervisor_session" -c "$project_path"
    sleep 0.5

    # Start Claude in supervisor session
    tmux send-keys -t "$supervisor_session" "claude --dangerously-skip-permissions" Enter

    # Wait for Claude to fully initialize (check for prompt)
    echo "Waiting for Supervisor Claude to initialize..."
    local max_wait=30
    local waited=0
    while [ $waited -lt $max_wait ]; do
        sleep 2
        waited=$((waited + 2))
        # Check if Claude prompt is visible (looking for the > prompt or bypass text)
        if tmux capture-pane -t "$supervisor_session" -p 2>/dev/null | grep -qE "(^> |bypass permissions)"; then
            echo "Supervisor Claude ready after ${waited}s"
            break
        fi
    done

    if [ $waited -ge $max_wait ]; then
        echo "Warning: Supervisor Claude may not be ready (waited ${max_wait}s)"
    fi

    # Build supervisor command with all options
    local supervisor_cmd="/supervisor $project_path --mode $mode"
    if [ -n "$offload_target" ]; then
        supervisor_cmd="$supervisor_cmd --offload $offload_target"
    fi

    # Send the supervisor slash command with project path and mode
    # The supervisor will spawn and manage workers itself
    tmux send-keys -t "$supervisor_session" "$supervisor_cmd" Enter
    sleep 3  # Wait for command to process

    echo "Supervisor started. It will spawn workers for each phase."
    echo ""

    # 2. Start heartbeat targeting the Supervisor
    echo "Starting heartbeat (sending updates every ${interval}s)..."
    # Kill any existing heartbeat for this project first
    pkill -f "auto-monitor.*${project_name}" 2>/dev/null || true
    sleep 0.5
    # Use nohup to survive SSH disconnection
    nohup "$SCRIPT_DIR/pipeline" auto-monitor "$project_path" --target "$supervisor_session" --interval "$interval" > /tmp/pipeline-${project_name}-heartbeat.log 2>&1 &
    local heartbeat_pid=$!
    disown $heartbeat_pid

    echo ""
    print_header "SUPERVISED PIPELINE RUNNING"
    echo ""
    echo "Supervisor: $supervisor_session"
    echo "Mode:       $mode"
    if [ -n "$offload_target" ]; then
        echo "Offload:    $offload_target"
    fi
    echo ""
    echo "The Supervisor Claude will:"
    echo "  1. Spawn a worker for the current phase"
    if [ -n "$offload_target" ]; then
        echo "     (workers run on $offload_target via SSH)"
    fi
    echo "  2. Monitor worker output to detect completion"
    echo "  3. Kill worker and spawn next phase worker"
    echo "  4. For phase 0a: wait for your approval"
    echo ""
    echo "Commands:"
    echo "  tmux attach -t $supervisor_session  # Watch Supervisor"
    echo "  ./pipeline status $project_path     # Check status"
    echo "  ./pipeline send $project_path --supervisor \"message\"  # Send to supervisor"
    echo ""
    echo "Logs (survives SSH disconnect):"
    echo "  /tmp/pipeline-${project_name}-heartbeat.log"
    echo ""
    echo "Pipeline running in background (safe to disconnect SSH)"
}

