#!/bin/bash
# Pipeline CLI v6.0 - Unified pipeline execution
# Usage: ./pipeline <command> [options]
#
# Commands:
#   run <project>                         Run full pipeline (0a→0b→1→2→3)
#   step <N> <project>                    Run individual step
#   status <project>                      Show pipeline status
#   watch <project>                       Reattach to running session
#   send <project> <message>              Send message to running session
#   stop <project>                        Stop running session gracefully
#   cleanup                               Clean up orphaned Xvfb/pm2 processes
#   analyze <project> [run-id]            Analyze completed run
#   resume <project>                      Resume stopped/paused session
#   help                                  Show this help message

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared libraries
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/transcript.sh"

# Show help
show_help() {
    cat << 'EOF'
Pipeline CLI v6.0 - Unified Pipeline Execution

USAGE:
    ./pipeline <command> [options]

COMMANDS:
    run <project>
        Run the complete pipeline (0a → 0b → 1 → 2 → 3).
        Opens a tmux session attached to Claude Code CLI.
        All phases run sequentially with auto-transitions.

        Controls while running:
          Ctrl+B D     Detach (pipeline keeps running)
          ./pipeline watch   Reattach to session
          ./pipeline send    Send message to session

    step <step> <project>
        Run individual pipeline step.
        Steps: 0a, 0b, 1, 2, 3

    status <project>
        Show current pipeline status.

    watch <project>
        Reattach to running pipeline session.
        Press Ctrl+B D to detach again.

    send <project> <message>
        Send message to running session.

    stop <project> [--graceful]
        Stop running session.
        With --graceful: saves session ID for exact conversation restoration.
        Also cleans up any orphaned Xvfb processes.

    cleanup
        Clean up orphaned processes from pipeline runs:
        - Xvfb (virtual displays from Cypress)
        - Stuck pm2 logs processes
        - Stale /tmp/.X*-lock files
        Run this after killing tmux manually.

    analyze <project> [run-id]
        Analyze completed pipeline run.

    resume <project> [--graceful]
        Resume a stopped/paused session.
        Normal: restarts current phase from scratch (new conversation).
        With --graceful: restores exact conversation (requires prior --graceful stop).

    signal <phase> [project] [options]  (DEPRECATED)
        Signal phase completion. DEPRECATED in v6.0 - supervisor now reads
        worker output to determine completion. Kept for backward compatibility.

    cost [command] [project]
        Token usage and cost tracking (uses ccusage).
        Commands: summary, live, monitor, session, ccusage
        Example: ./pipeline cost live ./my-project

EXAMPLES:
    # Start a new project
    ./pipeline run /home/claude/IMT/my-project

    # Run individual step
    ./pipeline step 2 /home/claude/IMT/my-project

    # Monitor running pipeline
    ./pipeline watch /home/claude/IMT/my-project
    ./pipeline status /home/claude/IMT/my-project

    # Interact with session
    ./pipeline send /home/claude/IMT/my-project "your message"
    ./pipeline stop /home/claude/IMT/my-project

VERSION: 6.0
EOF
}

# Command: modules - Manage reusable module library
cmd_modules() {
    source "$SCRIPT_DIR/lib/modules.sh"

    local subcmd="${1:-list}"
    shift || true

    case "$subcmd" in
        list)
            list_modules
            ;;
        apply)
            local module_name="${1:-}"
            local project_path="${2:-}"
            [ -z "$module_name" ] && die "Module name required. Usage: ./pipeline modules apply <name> <project>"
            [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline modules apply <name> <project>"
            project_path=$(realpath "$project_path" 2>/dev/null || echo "$project_path")
            apply_module "$project_path" "$module_name"
            ;;
        *)
            die "Unknown modules subcommand: $subcmd. Use: list, apply"
            ;;
    esac
}

