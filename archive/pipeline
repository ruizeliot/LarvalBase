# Command: cost - Token usage and cost tracking
cmd_cost() {
    source "$SCRIPT_DIR/lib/cost-tracker.sh" 2>/dev/null || die "Cost tracker not available"

    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        ""|summary)
            # Default: show project cost summary
            local project_path="${1:-$(pwd)}"
            project_path=$(realpath "$project_path")
            cost_print_summary "$project_path"
            ;;
        live)
            # Show live cost for running session
            local project_path="${1:-$(pwd)}"
            project_path=$(realpath "$project_path")
            local cost=$(cost_get_live_cost "$project_path")
            echo "Live Cost for $(basename "$project_path"):"
            echo "$cost" | jq '.'
            ;;
        monitor)
            # Start background cost monitor
            local project_path="${1:-$(pwd)}"
            local interval="${2:-30}"
            project_path=$(realpath "$project_path")
            cost_start_monitor "$project_path" "$interval"
            ;;
        session)
            # Show cost for specific session
            local session_id="${1:-}"
            [ -z "$session_id" ] && die "Session ID required. Usage: ./pipeline cost session <session-id>"
            local cost=$(cost_get_session_cost "$session_id")
            echo "Session Cost:"
            echo "$cost" | jq '.'
            ;;
        ccusage)
            # Run ccusage directly with passthrough args
            echo "Running ccusage..."
            npx ccusage@latest "$@"
            ;;
        *)
            echo "Usage: ./pipeline cost [command] [options]"
            echo ""
            echo "Commands:"
            echo "  summary [project]     Show project cost summary (default)"
            echo "  live [project]        Show live cost for running session"
            echo "  monitor [project] [N] Start cost monitor (updates every N seconds)"
            echo "  session <session-id>  Show cost for specific session"
            echo "  ccusage [args]        Run ccusage directly with any arguments"
            echo ""
            echo "Examples:"
            echo "  ./pipeline cost                    # Summary for current directory"
            echo "  ./pipeline cost live ./my-project  # Live cost tracking"
            echo "  ./pipeline cost ccusage daily      # Run ccusage daily report"
            echo "  ./pipeline cost ccusage blocks --live  # Real-time ccusage dashboard"
            ;;
    esac
}

# Main dispatcher
main() {
    local command="${1:-help}"
    shift || true

    case "$command" in
        run|r)
            cmd_run "$@"
            ;;
        step|s)
            cmd_step "$@"
            ;;
        status|st)
            cmd_status "$@"
            ;;
        watch|w)
            cmd_watch "$@"
            ;;
        monitor|mon)
            cmd_monitor "$@"
            ;;
        auto-monitor|am)
            cmd_auto_monitor "$@"
            ;;
        supervise|sup)
            cmd_supervise "$@"
            ;;
        send)
            cmd_send "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        cleanup)
            cmd_cleanup "$@"
            ;;
        analyze|a)
            cmd_analyze "$@"
            ;;
        resume|res)
            cmd_resume "$@"
            ;;
        transcript|tr)
            cmd_transcript "$@"
            ;;
        sessions|sess)
            cmd_sessions "$@"
            ;;
        stream)
            cmd_stream "$@"
            ;;
        modules|mod)
            cmd_modules "$@"
            ;;
        health|h)
            cmd_health "$@"
            ;;
        learn|l)
            cmd_learn "$@"
            ;;
        anti)
            cmd_anti "$@"
            ;;
        cost|$)
            cmd_cost "$@"
            ;;
        signal|sig)
            cmd_signal "$@"
            ;;
        help|--help|-?)
            show_help
            ;;
        version|--version|-v)
            echo "Pipeline CLI v$PIPELINE_VERSION"
            ;;
        *)
            die "Unknown command: $command. Run './pipeline help' for usage."
            ;;
    esac
}

main "$@"
