EOF

    if [ "$mode" = "feature" ]; then
        print_header "BRAINSTORM: New Feature"
    else
        print_header "BRAINSTORM: New Project"
    fi
    echo "Project: $project_path"
    echo "Run ID: $run_id"
    echo ""
    echo "This is an INTERACTIVE session."
    echo "You will brainstorm with Claude to create user stories."
    print_header ""

    local transcript="$run_dir/$transcript_name"
    write_transcript_header "$transcript" "$step" "$project_path" "$run_id"

    # Setup control files
    local input_file="$project_path/.pipeline/.input"
    local stop_file="$project_path/.pipeline/.stop"
    local status_file="$project_path/.pipeline/.exit_status"
    local stop_marker="$project_path/.pipeline/.stop_writing"
    local session_file="$project_path/.pipeline/session-id"
    rm -f "$stop_file" "$input_file" "$status_file" "$stop_marker"

    echo ""
    echo "To send input: ./pipeline send $project_path \"your message\""
    echo "To stop:       ./pipeline stop $project_path"
    echo "To resume:     ./pipeline resume $project_path"
    echo ""

    # Run expect with dual output (pass session_file as 7th arg for resume support)
    cd "$project_path"
    { expect "$SCRIPT_DIR/lib/expect-interactive.exp" "$slash_cmd" "$input_file" "$stop_file" "$status_file" "$stop_marker" "" "$session_file" 2>/dev/null || true; } | \
      stdbuf -oL tee >(clean_transcript_with_stop "$stop_marker" >> "$transcript")

    sleep 2
    rm -f "$stop_marker"

    # Read exit status
    local exit_status="unknown"
    if [ -f "$status_file" ]; then
        exit_status=$(cat "$status_file")
        rm -f "$status_file"
    fi

    # Calculate duration
    local end_time=$(date +%s)
    local end_iso=$(date -Iseconds)
    local duration=$((end_time - start_time))

    # Add footer based on status
    echo "" >> "$transcript"
    echo "---" >> "$transcript"
    echo "" >> "$transcript"

    local metadata_status="unknown"
    local display_status="Brainstorm Ended"

    case "$exit_status" in
        "complete")
            echo "**Ended:** $end_iso" >> "$transcript"
            echo "**Duration:** ${duration}s" >> "$transcript"
            echo "**Status:** Complete" >> "$transcript"
            metadata_status="complete"
            display_status="Brainstorm Complete"
            ;;
        "stopped")
            echo "**Stopped:** $end_iso" >> "$transcript"
            echo "**Duration:** ${duration}s" >> "$transcript"
            metadata_status="stopped"
            display_status="Brainstorm Stopped by User"
            ;;
        "failed")
            echo "**Ended:** $end_iso" >> "$transcript"
            echo "**Duration:** ${duration}s" >> "$transcript"
            echo "**Status:** Failed" >> "$transcript"
            metadata_status="failed"
            display_status="Brainstorm Failed"
            ;;
        *)
            echo "**Ended:** $end_iso" >> "$transcript"
            echo "**Duration:** ${duration}s" >> "$transcript"
            echo "**Status:** Unknown" >> "$transcript"
            ;;
    esac

    # Update metadata
    jq --arg endedAt "$end_iso" \
       --arg duration "$duration" \
       --arg status "$metadata_status" \
       '. + {endedAt: $endedAt, durationSeconds: ($duration | tonumber), status: $status}' \
       "$run_dir/metadata.json" > "$run_dir/metadata.tmp" && mv "$run_dir/metadata.tmp" "$run_dir/metadata.json"

    echo ""
    print_header "$display_status"
    echo ""
    echo "Run ID: $run_id"
    echo "Duration: $(format_duration $duration)"
    echo "Status: $exit_status"
    echo ""

    if [ "$exit_status" = "stopped" ]; then
        echo "To resume: ./pipeline resume $project_path"
        echo ""
    fi

    echo "To continue with automated pipeline:"
    if [ "$mode" = "feature" ]; then
        echo "  ./pipeline run $project_path --feature"
    else
        echo "  ./pipeline run $project_path"
    fi
    print_header ""
}

# Command: run (automated pipeline with separate Claude per phase)
cmd_run() {
    local project_path=""
    local feature_mode=""
    local from_phase=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --feature|-f)
                feature_mode="--feature"
                shift
                ;;
            --from)
                from_phase="$2"
                shift 2
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                if [ -z "$project_path" ]; then
                    project_path="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline run <project> [--feature] [--from <phase>]"

    # Create project directory if it doesn't exist
    if [ ! -d "$project_path" ]; then
        echo "Creating project directory: $project_path"
        mkdir -p "$project_path"
    fi

    project_path=$(realpath "$project_path")

    # Initialize manifest ONLY if it doesn't exist or has no progress/epics
    local manifest_file="$project_path/.pipeline/manifest.json"
    local should_init=true

    if [[ -f "$manifest_file" ]]; then
        # Check if any phase beyond 0a is complete (has progress)
        local has_progress=$(jq -r '
            .phases | to_entries |
            map(select(.key != "0a" and .value.status == "complete")) |
            length > 0
        ' "$manifest_file" 2>/dev/null || echo "false")

        # Also check if manifest has epics defined
        local has_epics=$(jq -r '.epics | length > 0' "$manifest_file" 2>/dev/null || echo "false")

        # Check if 0a is pending (fresh start, should preserve)
        local phase_0a_pending=$(jq -r '.phases["0a"].status == "pending"' "$manifest_file" 2>/dev/null || echo "false")

        if [[ "$has_progress" == "true" ]]; then
            echo "Existing manifest with progress found - preserving"
            should_init=false
        elif [[ "$has_epics" == "true" ]]; then
            echo "Existing manifest with epics found - preserving"
            should_init=false
        elif [[ "$phase_0a_pending" == "true" ]]; then
            echo "Existing manifest with 0a pending - preserving for fresh start"
            should_init=false
        fi
    fi

    if [[ "$should_init" == "true" ]]; then
        local run_id=$(date +%Y%m%d-%H%M%S)
        "$SCRIPT_DIR/init-manifest.sh" "$project_path" "$run_id" "new-project" 2>/dev/null || true
    fi

    # Run the unified pipeline script
    local from_arg=""
    if [[ -n "$from_phase" ]]; then
        from_arg="--from $from_phase"
    fi
    exec "$SCRIPT_DIR/run-pipeline.sh" "$project_path" $feature_mode $from_arg
}

# Command: step (run individual step)
cmd_step() {
    local step=""
    local project_path=""
    local mode="new"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --feature|-f)
                mode="feature"
                shift
                ;;
            -*)
                die "Unknown option: $1"
                ;;
            *)
                if [ -z "$step" ]; then
                    step="$1"
                elif [ -z "$project_path" ]; then
                    project_path="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [ -z "$step" ] && die "Step required. Usage: ./pipeline step <step> <project> [--feature]"
    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline step <step> <project> [--feature]"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    # Execute run-step.sh
    exec "$SCRIPT_DIR/run-step.sh" "$step" "$project_path" "$mode"
}

# Command: status
cmd_status() {
    local project_path="$1"

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline status <project>"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"
    require_jq

    local manifest="$project_path/.pipeline/manifest.json"
    local current_run_file="$project_path/.pipeline/current-run.txt"

    print_header "PIPELINE STATUS"
    echo ""
    echo "Project: $(basename "$project_path")"
    echo "Path: $project_path"
    echo ""

    # Check for current run
    if [ -f "$current_run_file" ]; then
        local run_id=$(cat "$current_run_file")
        local run_meta="$project_path/.pipeline/runs/$run_id/metadata.json"

        if [ -f "$run_meta" ]; then
            local run_status=$(jq -r '.status // "unknown"' "$run_meta")
            local run_type=$(jq -r '.type // "unknown"' "$run_meta")
            local started_at=$(jq -r '.startedAt // "unknown"' "$run_meta")

            echo "Current Run: $run_id"
            echo "Type: $run_type"
            echo "Status: $run_status"
            echo "Started: $started_at"

            if [ "$run_status" = "running" ]; then
                # Check if input/stop files exist
                [ -f "$project_path/.pipeline/.input" ] && echo "  (pending input)"
                [ -f "$project_path/.pipeline/.stop" ] && echo "  (stop requested)"
            fi
            echo ""
        fi
    else
        echo "No active run found."
        echo ""
    fi

    # Check manifest
    if [ -f "$manifest" ]; then
        local current_phase=$(jq -r '.currentPhase // "unknown"' "$manifest")
        local current_epic=$(jq -r '.currentEpic // 0' "$manifest")
        local total_epics=$(jq '.epics | length // 0' "$manifest")
        local completed_epics=$(jq '[.epics[] | select(.status == "complete")] | length' "$manifest")
        local tests_passing=$(jq -r '.tests.passing // 0' "$manifest")
        local tests_total=$(jq -r '.tests.total // 0' "$manifest")
        local project_status=$(jq -r '.status // "unknown"' "$manifest")

        echo "Phase: $current_phase ($(get_step_name "$current_phase"))"
        echo "Epic: $current_epic / $total_epics ($completed_epics complete)"
        echo "Tests: $tests_passing / $tests_total passing"
        echo "Overall: $project_status"
        echo ""

        # Show epic details
        echo "Epics:"
        jq -r '.epics[] | "  \(.id). \(.name): \(.status)"' "$manifest"
    else
        echo "No manifest found. Run brainstorm first."
    fi

    print_header ""
}

# Command: watch - Attach to live Claude Code CLI session (or tail log in foreground mode)
cmd_watch() {
    local project_path="$1"

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline watch <project>"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    local project_name=$(basename "$project_path")
    local log_file="$project_path/.pipeline/pipeline.log"

    # Check if tmux is available
    if ! command -v tmux &>/dev/null; then
        # Foreground mode - tail the log file
        print_header "PIPELINE WATCH (foreground mode)"
        echo ""
        echo "Project: $project_name"
        echo "Log file: $log_file"
        echo ""

        if [ ! -f "$log_file" ]; then
            echo "No log file found. Start pipeline first with:"
            echo "  ./pipeline run $project_path"
            return 1
        fi

        echo "Tailing log file (Ctrl+C to stop)..."
        echo "────────────────────────────────────────────────────────────────"
        tail -f "$log_file"
        return 0
    fi

    # tmux mode
    local session_prefix="pipeline-${project_name}"

    # Find active sessions sorted by creation time (newest first)
    local sessions=$(tmux ls 2>/dev/null | grep "^${session_prefix}" | sort -t'(' -k2 -r)

    if [ -z "$sessions" ]; then
        # No tmux session - check for log file (might be foreground mode)
        if [ -f "$log_file" ]; then
            echo "No tmux session, but log file exists. Tailing..."
            echo "────────────────────────────────────────────────────────────────"
            tail -f "$log_file"
            return 0
        fi

        print_header "PIPELINE WATCH"
        echo ""
        echo "Project: $project_name"
        echo "No active sessions found."
        echo ""
        echo "Start a pipeline first with:"
        echo "  ./pipeline run $project_path"
        print_header ""
        return 1
    fi

    local session_count=$(echo "$sessions" | wc -l)
    local latest_session=$(echo "$sessions" | head -1 | cut -d: -f1)

    # If multiple sessions, show selection
    if [ "$session_count" -gt 1 ]; then
        echo "Multiple sessions found ($session_count):"
        echo ""
        local i=1
        echo "$sessions" | while read -r line; do
            local sess_name=$(echo "$line" | cut -d: -f1)
            echo "  $i) $sess_name"
            i=$((i+1))
        done
        echo ""
        echo "Attaching to latest: $latest_session"
        echo "(Press Ctrl+B then D to detach)"
        echo ""
        sleep 2
    else
        echo "Attaching to: $latest_session"
        echo "(Press Ctrl+B then D to detach)"
        sleep 1
    fi

    # Attach to the tmux session (read-only mode)
    tmux attach-session -t "$latest_session" -r
}

# Command: send - Send message to running pipeline session (or write to file in foreground mode)
cmd_send() {
    local project_path=""
    local target="worker"  # Default to worker
    local message_parts=()

    # Parse arguments - flags can appear anywhere
    while [[ $# -gt 0 ]]; do
        case $1 in
            --supervisor|-s)
                target="supervisor"
                shift
                ;;
            --worker|-w)
                target="worker"
                shift
                ;;
            --target|-t)
                target="$2"
                shift 2
                ;;
            -*)
                die "Unknown option: $1. Usage: ./pipeline send <project> <message> [--supervisor|--worker]"
                ;;
            *)
                if [ -z "$project_path" ]; then
                    project_path="$1"
                else
                    message_parts+=("$1")
                fi
                shift
                ;;
        esac
    done

    local message="${message_parts[*]}"

    [ -z "$project_path" ] && die "Usage: ./pipeline send <project> [--supervisor|--worker] <message>"
    [ -z "$message" ] && die "Message required. Usage: ./pipeline send <project> [--supervisor|--worker] <message>"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    local project_name=$(basename "$project_path")
    local msg_file="$project_path/.pipeline/user-message.txt"

    # Check if tmux is available
    if ! command -v tmux &>/dev/null; then
        # Foreground mode - write to message file
        echo "$message" > "$msg_file"
        success "Message queued (foreground mode)"
        echo "The pipeline will read this on next check."
        return 0
    fi

    local session_name="${target}-${project_name}"

    # Check if session exists
    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        # Try legacy naming (pipeline-* for backwards compatibility)
        local legacy_session="pipeline-${project_name}"
        if [ "$target" = "worker" ] && tmux has-session -t "$legacy_session" 2>/dev/null; then
            session_name="$legacy_session"
        else
            # No tmux session - try file-based messaging (foreground mode might be running)
            if [ -d "$project_path/.pipeline" ]; then
                echo "$message" > "$msg_file"
                success "Message queued (file-based, no tmux session found)"
                echo "If pipeline is running in foreground mode, it will read this."
                return 0
            fi
            die "No active $target session found ($session_name). Start with: ./pipeline supervise $project_path"
        fi
    fi

    # Format message - add [User]: prefix for supervisor messages
    local formatted_message="$message"
    if [ "$target" = "supervisor" ]; then
        formatted_message="[User]: $message"
    fi

    # STEP 1: Exit copy-mode if active (q exits copy-mode, harmless otherwise)
    tmux send-keys -t "$session_name" q >/dev/null 2>&1
    sleep 0.2

    # STEP 2: Send Ctrl-C to interrupt any running operation (works in Claude)
    tmux send-keys -t "$session_name" C-c >/dev/null 2>&1
    sleep 0.5

    # STEP 3: Clear any existing input
    tmux send-keys -t "$session_name" C-u >/dev/null 2>&1
    sleep 0.2

    # STEP 4: Type the message (literal mode to avoid special char issues)
    tmux send-keys -t "$session_name" -l "$formatted_message"
    sleep 0.2

    # STEP 5: Submit with Enter
    tmux send-keys -t "$session_name" Enter

    success "Message sent to $target ($session_name)"
}

# Command: stop - Stop running pipeline session
# With --graceful: saves session ID for exact conversation restoration
cmd_stop() {
    local project_path=""
    local graceful_mode=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --graceful|-g)
                graceful_mode="true"
                shift
                ;;
            -*)
                die "Unknown option: $1. Usage: ./pipeline stop <project> [--graceful]"
                ;;
            *)
                project_path="$1"
                shift
                ;;
        esac
    done

    [ -z "$project_path" ] && die "Project path required. Usage: ./pipeline stop <project> [--graceful]"

    project_path=$(realpath "$project_path")
    validate_project_path "$project_path"

    local project_name=$(basename "$project_path")
    local pipeline_dir="$project_path/.pipeline"
    local graceful_state="$pipeline_dir/graceful-state.json"

    # Try multiple session naming patterns
    local session_name=""
    for pattern in "worker-${project_name}" "pipeline-${project_name}" "supervisor-${project_name}"; do
        if tmux has-session -t "$pattern" 2>/dev/null; then
            session_name="$pattern"
            break
        fi
    done

    # Check for foreground mode (no tmux but log exists)
    local foreground_mode=""
    if [[ -z "$session_name" ]] && [[ -f "$pipeline_dir/pipeline.log" ]]; then
        foreground_mode="true"
    fi

    if [[ -z "$session_name" ]] && [[ -z "$foreground_mode" ]]; then
        echo "No active session found for $project_name"
        return 0
    fi

    # GRACEFUL MODE: Save session state before stopping
    if [[ "$graceful_mode" == "true" ]]; then
        echo "Graceful stop: saving session state..."

        # Find the latest session ID from Claude's JSONL files
        local session_id=""
        local claude_dir="$HOME/.claude/projects"
        local encoded_path=$(echo "$project_path" | sed 's|^/||; s|/|-|g; s|^|-|')
        local project_sessions="$claude_dir/$encoded_path"

        # Windows path encoding (different format)
        if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "${WINDIR:-}" ]]; then
            # Convert Windows path: C:\Users\foo -> -C-Users-foo
            encoded_path=$(echo "$project_path" | sed 's|\\|/|g; s|:|/|; s|^/||; s|/|-|g; s|^|-|')
            project_sessions="$claude_dir/$encoded_path"
        fi

        if [[ -d "$project_sessions" ]]; then
            # Find latest non-agent session
            local latest_jsonl=$(ls -t "$project_sessions"/*.jsonl 2>/dev/null | grep -v '/agent-' | head -1)
            if [[ -n "$latest_jsonl" ]]; then
                session_id=$(basename "$latest_jsonl" .jsonl)
                echo "  Found session: $session_id"
            fi
        fi

        # Read current manifest state
        local manifest="$pipeline_dir/manifest.json"
        local current_phase="unknown"
        local current_epic="0"
        local todo_progress="[]"

        if [[ -f "$manifest" ]]; then
            current_phase=$(jq -r '.currentPhase // "unknown"' "$manifest")
            current_epic=$(jq -r '.currentEpic // 0' "$manifest")
        fi

        # Save graceful state
        local timestamp=$(date -Iseconds)
        cat > "$graceful_state" << EOF
{
  "sessionId": "${session_id:-}",
  "savedAt": "$timestamp",
  "currentPhase": "$current_phase",
  "currentEpic": $current_epic,
  "projectPath": "$project_path",
  "canGracefulResume": ${session_id:+true}${session_id:-false}
}
EOF

        if [[ -n "$session_id" ]]; then
            # Also save to session-id file for compatibility
            echo "$session_id" > "$pipeline_dir/session-id"
            success "Session state saved"
            echo "  Session ID: $session_id"
            echo "  Phase: $current_phase"
            echo "  State file: $graceful_state"
        else
            warn "Could not find session ID - graceful resume may not work"
            echo "  Normal resume (restart phase) will still work"
        fi
    fi

    # Stop the session
    if [[ -n "$session_name" ]]; then
        # tmux mode
        tmux send-keys -t "$session_name" C-u
        tmux send-keys -t "$session_name" "/exit" Enter
        sleep 2
        tmux kill-session -t "$session_name" 2>/dev/null || true
    elif [[ "$foreground_mode" == "true" ]]; then
        # Foreground mode - signal stop via file
        echo "STOP" > "$pipeline_dir/.stop"
        echo "Stop signal sent to foreground process"
    fi

    # Clean up orphaned Xvfb processes from Cypress tests (Linux only)
    if command -v pgrep &>/dev/null; then
        local xvfb_count=$(pgrep -u "$(whoami)" -f "^Xvfb :" 2>/dev/null | wc -l) || xvfb_count=0
        if [ "$xvfb_count" -gt 0 ]; then
            pkill -u "$(whoami)" -f "^Xvfb :" 2>/dev/null || true
            rm -f /tmp/.X[0-9]*-lock 2>/dev/null || true
            echo "Cleaned up $xvfb_count orphaned Xvfb process(es)"
        fi
    fi

    success "Pipeline stopped for $project_name"

    if [[ "$graceful_mode" == "true" ]]; then
        echo ""
        echo "To resume exact conversation:"
        echo "  ./pipeline resume --graceful $project_path"
        echo ""
        echo "To restart phase from scratch:"
        echo "  ./pipeline resume $project_path"
    fi
}

# Command: cleanup - Clean up orphaned processes from pipeline runs
cmd_cleanup() {
    echo "Cleaning up orphaned pipeline processes..."

    # Clean up Xvfb processes (from Cypress)
    local xvfb_count=$(pgrep -u "$(whoami)" -f "^Xvfb :" 2>/dev/null | wc -l)
    if [ "$xvfb_count" -gt 0 ]; then
        pkill -u "$(whoami)" -f "^Xvfb :" 2>/dev/null || true
        echo "  Killed $xvfb_count Xvfb process(es)"
    else
        echo "  No orphaned Xvfb processes"
    fi

    # Clean up stale lock files
    local lock_count=$(ls /tmp/.X[0-9]*-lock 2>/dev/null | wc -l)
    if [ "$lock_count" -gt 0 ]; then
        rm -f /tmp/.X[0-9]*-lock 2>/dev/null || true
        echo "  Removed $lock_count Xvfb lock file(s)"
    else
        echo "  No stale lock files"
    fi

    # Clean up stuck pm2 logs processes
    local pm2logs_count=$(pgrep -u "$(whoami)" -f "pm2 logs" 2>/dev/null | wc -l)
    if [ "$pm2logs_count" -gt 0 ]; then
        pkill -u "$(whoami)" -f "pm2 logs" 2>/dev/null || true
        echo "  Killed $pm2logs_count stuck pm2 logs process(es)"
    else
        echo "  No stuck pm2 logs processes"
    fi

    success "Cleanup complete"
}

