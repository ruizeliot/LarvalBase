{
  "name": "@imt/pipeline",
  "version": "7.0.0",
  "description": "Pipeline v7 - TUI application for automated development pipeline orchestration",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "pipeline": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/imt/pipeline-v7.git"
  },
  "homepage": "https://gitlab.com/imt/pipeline-v7#readme",
  "bugs": {
    "url": "https://gitlab.com/imt/pipeline-v7/issues"
  },
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --dts",
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.2.0",
    "chalk": "^5.3.0",
    "conf": "^12.0.0",
    "meow": "^13.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pipeline",
    "cli",
    "tui",
    "ink",
    "orchestration",
    "automation"
  ],
  "author": "IMT",
  "license": "MIT"
}
