{
  "name": "cascadesim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,collab -c blue,green \"npm:dev:vite\" \"npm:dev:collab\"",
    "dev:vite": "vite",
    "dev:collab": "node scripts/yjs-server.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
